<?xml version="1.0"?>
<robot name="extractor_continuous_wrist">

  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <link name="upper_arm"/>
  <link name="forearm"/>
  <link name="wrist"/>

  <joint name="shoulder" type="revolute">
    <parent link="base_link"/>
    <child link="upper_arm"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" velocity="2.0" effort="50.0"/>
  </joint>

  <joint name="elbow" type="revolute">
    <parent link="upper_arm"/>
    <child link="forearm"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" velocity="2.0" effort="50.0"/>
  </joint>

  <joint name="wrist_roll" type="continuous">
    <parent link="forearm"/>
    <child link="wrist"/>
    <origin xyz="0.2 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit velocity="6.0" effort="10.0"/>
  </joint>

</robot>

<?xml version="1.0"?>
<robot name="extractor_serial_minimal">

  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <link name="link_1"/>
  <link name="link_2"/>
  <link name="tool"/>

  <joint name="shoulder" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" velocity="2.0" effort="50.0"/>
  </joint>

  <joint name="extender" type="prismatic">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.5" velocity="0.5" effort="100.0"/>
  </joint>

  <joint name="wrist" type="revolute">
    <parent link="link_2"/>
    <child link="tool"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" velocity="3.0" effort="20.0"/>
  </joint>

</robot>

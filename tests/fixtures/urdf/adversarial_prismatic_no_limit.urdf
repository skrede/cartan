<?xml version="1.0"?>
<!-- Prismatic joint without the required <limit lower upper>. A prismatic
     joint is always bounded per the URDF spec; rejected as missing_joint_limit. -->
<robot name="adversarial_prismatic_no_limit">

  <link name="base_link"/>
  <link name="tip"/>

  <joint name="unbounded_prismatic" type="prismatic">
    <parent link="base_link"/>
    <child link="tip"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>

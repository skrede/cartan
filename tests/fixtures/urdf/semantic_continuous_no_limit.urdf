<?xml version="1.0"?>
<!-- Continuous joint without <limit>. A continuous joint is unbounded by
     definition, so this remains VALID and loads with +/- infinity limits. -->
<robot name="semantic_continuous_no_limit">

  <link name="base_link"/>
  <link name="tip"/>

  <joint name="free_spin_joint" type="continuous">
    <parent link="base_link"/>
    <child link="tip"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>
